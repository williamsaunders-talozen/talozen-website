                </span>
              </nav>
              <div class="fp-tenant__body" data-tenant-loading>
                <div class="fp-tenant__loader" aria-hidden="true">
                  <svg class="fp-tenant__load-spinner" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" stroke="var(--border-default)" stroke-width="2.5"/>
                    <path d="M12 2a10 10 0 0 1 10 10" stroke="var(--text-brand)" stroke-width="2.5" stroke-linecap="round"/>
                  </svg>
                  <span class="fp-tenant__loader-text">Loading lease application…</span>
                </div>
                <div class="fp-tenant__left">
                  <div class="fp-tenant__card">
                    <div class="fp-tenant__card-row">
                      <img class="fp-tenant__avatar-circle" src="/assets/docs/naledi-avatar.png" alt="" width="56" height="56" loading="lazy" />
                      <span class="fp-tenant__name">Naledi Mahlangu</span>
                    </div>
                    <p class="fp-tenant__detail">naledi.mahlangu@gmail.com</p>
                    <p class="fp-tenant__detail">+27 72 845 3291</p>
                    <p class="fp-tenant__detail">ID: 9108230184086</p>
                    <p class="fp-tenant__detail">Country of citizenship: South Africa</p>
                    <p class="fp-tenant__detail">Sex: Female</p>
                    <p class="fp-tenant__detail">Age: 34</p>
                    <p class="fp-tenant__detail">Date of birth: 23/08/1991</p>
                    <p class="fp-tenant__detail">Marital status: Married - OCP with accrual</p>
                  </div>
                  <div class="fp-tenant__card">
                    <p class="fp-tenant__card-heading">Address</p>
                    <p class="fp-tenant__detail">14 Rivonia Road</p>
