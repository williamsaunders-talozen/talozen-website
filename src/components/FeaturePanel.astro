---
interface Item {
  title: string;
  body: string;
  icon?: string;
}

interface Props {
  headline: string;
  subheadline?: string;
  items?: Item[];
  embedUrl?: string;
  embedTitle?: string;
  imagePosition?: "left" | "right";
  background?: "default" | "secondary";
  mediaType?: "embed" | "wireframe" | "mandate" | "tenant";
  cta?: string;
  ctaHref?: string;
}

const { headline, subheadline, items, embedUrl, embedTitle, imagePosition = "left", background = "default", mediaType = "embed", cta, ctaHref } = Astro.props;
const reversed = imagePosition === "right";

const iconMap: Record<string, string> = {
  'Self-Service Onboarding': 'user-plus',
  'Complex Entity Handling': 'building',
  'Multi-signature handling': 'pen-tool',
  '24/7 Application Engine': 'clock',
  'One-Click Credit Checks': 'shield-check',
  'Payment-Triggered Contracts': 'credit-card',
  'Proactive Expiry Tracking': 'calendar',
  'Controlled Approval Gateways': 'lock',
  'Frictionless Closing': 'zap',
  'Real-Time Dashboards': 'bar-chart',
  'Agent Performance Tracking': 'trending-up',
  'Compliance Guard Rails': 'shield',
};

function getIcon(title: string): string {
  return iconMap[title] || 'check';
}

const applicants: { name: string; photo: string; credit: 'button' | 'processing' | 'complete' }[] = [
  { name: 'Davia Markon',    photo: 'https://i.pravatar.cc/56?img=32', credit: 'button' },
  { name: 'James Wright',    photo: 'https://i.pravatar.cc/56?img=11', credit: 'button' },
  { name: 'Nomsa Khumalo',   photo: 'https://i.pravatar.cc/56?img=47', credit: 'processing' },
  { name: 'Sarah Chen',      photo: 'https://i.pravatar.cc/56?img=5',  credit: 'complete' },
  { name: 'Thabo Molefe',    photo: 'https://i.pravatar.cc/56?img=12', credit: 'processing' },
  { name: 'Nina Patel',      photo: 'https://i.pravatar.cc/56?img=23', credit: 'complete' },
  { name: 'David Okonkwo',   photo: 'https://i.pravatar.cc/56?img=53', credit: 'complete' },
  { name: 'Amahle Dube',     photo: 'https://i.pravatar.cc/56?img=44', credit: 'processing' },
  { name: 'Lerato Mokoena',  photo: 'https://i.pravatar.cc/56?img=26', credit: 'complete' },
  { name: 'Benny Baden',     photo: 'https://i.pravatar.cc/56?img=59', credit: 'processing' },
  { name: 'Zinhle Nkosi',    photo: 'https://i.pravatar.cc/56?img=9',  credit: 'complete' },
  { name: 'Pieter van Wyk',  photo: 'https://i.pravatar.cc/56?img=60', credit: 'processing' },
];
---

<section class:list={["feature-panel", { "feature-panel--secondary": background === "secondary" }]}>
  <div class="tz-container">
    <div class:list={["feature-panel__inner", "reveal", { "feature-panel__inner--reversed": reversed }]}>
      <div class="feature-panel__media">
        {mediaType === "wireframe" ? (
          <div class="fp-preview" role="img" aria-label="Product wireframe preview — applications">
            <div class="fp-preview__frame">
              <header class="fp-preview__header">
                <img class="fp-preview__property-img" src="https://images.unsplash.com/photo-1567684014761-b65e2e59b9eb?w=120&h=120&fit=crop&crop=center" alt="" width="120" height="120" loading="lazy" />
                <div class="fp-preview__header-text">
                  <p class="fp-preview__address">183 Beach Road, Sea Point, Cape Town</p>
                  <p class="fp-preview__address-sub">Sea Point Place · 166 units</p>
                </div>
              </header>
              <nav class="fp-preview__steps" aria-label="Workflow">
                <span class="fp-preview__pill">
                  <svg class="fp-preview__pill-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  Applications
                </span>
                <span class="fp-preview__arrow" aria-hidden="true">→</span>
                <span class="fp-preview__pill fp-preview__pill--active">
                  <svg class="fp-preview__pill-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                  Approvals
                </span>
                <span class="fp-preview__arrow" aria-hidden="true">→</span>
                <span class="fp-preview__pill">
                  <svg class="fp-preview__pill-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  Generate and sign
                </span>
              </nav>
              <div class="fp-preview__main">
                <h3 class="fp-preview__title">25 Applications received</h3>
                <ul class="fp-preview__list">
                  {applicants.map((person, i) => (
                    <li class="fp-preview__card" style={`--card-i: ${i}`}>
                      <img class="fp-preview__avatar" src={person.photo} alt="" width="56" height="56" loading="lazy" />
                      <span class="fp-preview__name">{person.name}</span>
                      <span class="fp-preview__pay">R300.00 paid</span>
                      <div class="fp-preview__fica">
                        <svg class="fp-preview__check" width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M20 6L9 17l-5-5"/></svg>
                        <span>FICA</span>
                      </div>
                      {person.credit === 'button' && (
                        <button type="button" class="fp-preview__action" tabindex="-1">Run credit check</button>
                      )}
                      {person.credit === 'processing' && (
                        <span class="fp-preview__status fp-preview__status--processing">Processing</span>
                      )}
                      {person.credit === 'complete' && (
                        <span class="fp-preview__status fp-preview__status--complete">A rating</span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ) : mediaType === "mandate" ? (
          <div class="fp-browser-shell">
            <div class="fp-browser-shell__chrome">
              <div class="fp-browser-shell__dots">
                <span class="fp-browser-shell__dot fp-browser-shell__dot--red"></span>
                <span class="fp-browser-shell__dot fp-browser-shell__dot--yellow"></span>
                <span class="fp-browser-shell__dot fp-browser-shell__dot--green"></span>
              </div>
              <div class="fp-browser-shell__urlbar">
                <span class="fp-browser-shell__url">www.talozen.com</span>
