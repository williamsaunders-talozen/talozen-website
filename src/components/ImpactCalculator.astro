---
interface Props {
  headline: string;
}

const { headline } = Astro.props;
---

<section class="calculator tz-textured">
  <div class="tz-container">
    <div class="calculator__card tz-card reveal">

      <div class="calculator__header">
        <div class="calculator__icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="40" height="40" rx="10" fill="var(--bg-brand-tertiary)" />
            <rect x="12" y="10" width="16" height="20" rx="2" stroke="var(--text-brand)" stroke-width="1.5" fill="none"/>
            <rect x="14" y="12" width="12" height="4" rx="1" fill="var(--bg-brand-secondary)" />
            <line x1="14" y1="20" x2="18" y2="20" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="22" y1="20" x2="26" y2="20" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="14" y1="24" x2="18" y2="24" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="22" y1="24" x2="26" y2="24" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="14" y1="28" x2="18" y2="28" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="22" y1="28" x2="26" y2="28" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h2 class="calculator__heading">{headline}</h2>
      </div>

      <div class="calculator__body">
        <div class="calculator__input-panel">
          <div class="calculator__field">
            <label class="calculator__label" for="agent-count">Number of agents</label>
            <div class="calculator__stepper">
              <button class="calculator__stepper-btn" id="stepper-down" aria-label="Decrease">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 10h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
              <input
                id="agent-count"
                class="calculator__stepper-input"
                type="number"
                min="1"
                max="500"
                value="5"
              />
              <button class="calculator__stepper-btn" id="stepper-up" aria-label="Increase">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M10 5v10M5 10h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div class="calculator__metric calculator__metric--hero">
          <div class="calculator__metric-text">
            <span class="calculator__metric-label">Admin hours saved per year</span>
            <span class="calculator__metric-value" id="hours-saved">5,200 hours</span>
            <span class="calculator__metric-note">Saving 4 hours per day</span>
          </div>
        </div>

        <div class="calculator__metric calculator__metric--hero">
          <div class="calculator__metric-text">
            <span class="calculator__metric-label">Admin cost saved per year</span>
            <span class="calculator__metric-value" id="cost-saved">R590,909</span>
            <span class="calculator__metric-note">R20,000 monthly cost per agent</span>
          </div>
        </div>
      </div>

      <div class="calculator__impact">
        <div class="calculator__impact-icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
            <path d="M9 21h6M12 3a6 6 0 014 10.5V17a1 1 0 01-1 1h-6a1 1 0 01-1-1v-3.5A6 6 0 0112 3z" stroke="var(--text-brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
        <div class="calculator__impact-text">
          <p class="calculator__impact-line">That's like having an extra <strong id="ftes-freed">2.5</strong> agents working for you.</p>
          <p class="calculator__impact-line">And <strong id="workdays-unlocked">100</strong> extra hours per week to focus on deals and customers.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const HOURS_PER_DAY = 4;
  const WORKING_DAYS = 260;
  const MONTHLY_COST = 20000;
  const HOURLY_COST = MONTHLY_COST / (22 * 8);

  function fmt(n: number) {
    return n.toLocaleString("en-ZA");
  }

  const counters: Record<string, { current: number; target: number; raf: number }> = {
    hours:    { current: 5200,   target: 5200,   raf: 0 },
    cost:     { current: 590909, target: 590909, raf: 0 },
    ftes:     { current: 2.5,    target: 2.5,    raf: 0 },
    workdays: { current: 100,    target: 100,    raf: 0 },
  };

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function animateCounter(
    key: string,
    el: HTMLElement,
    target: number,
    formatter: (n: number) => string,
    isFloat = false
  ) {
    const c = counters[key];
    cancelAnimationFrame(c.raf);
    c.target = target;

    if (reducedMotion) {
      c.current = target;
      el.textContent = formatter(target);
      return;
    }

    const duration = 400;
    const start = performance.now();
    const from = c.current;
    const delta = target - from;

    function tick(now: number) {
      const elapsed = now - start;
      const t = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - t, 4);
      const val = from + delta * ease;
      c.current = t === 1 ? target : val;
      el.textContent = formatter(isFloat ? parseFloat(val.toFixed(1)) : Math.round(val));
      if (t < 1) c.raf = requestAnimationFrame(tick);
    }

    c.raf = requestAnimationFrame(tick);
  }

  function update(agents: number) {
    const hoursSaved = agents * HOURS_PER_DAY * WORKING_DAYS;
    const costSaved = Math.round(hoursSaved * HOURLY_COST);
    const ftesFreed = hoursSaved / 2080;
    const hoursPerWeek = Math.round(hoursSaved / 52);

    animateCounter('hours', document.getElementById("hours-saved")!, hoursSaved, (n) => `${fmt(n)} hours`);
    animateCounter('cost', document.getElementById("cost-saved")!, costSaved, (n) => `R${fmt(n)}`);
    animateCounter('ftes', document.getElementById("ftes-freed")!, ftesFreed, (n) => n.toFixed(1), true);
    animateCounter('workdays', document.getElementById("workdays-unlocked")!, hoursPerWeek, fmt);
  }

  const input = document.getElementById("agent-count") as HTMLInputElement;
  const downBtn = document.getElementById("stepper-down")!;
  const upBtn = document.getElementById("stepper-up")!;

  function getVal() { return Math.max(1, parseInt(input.value) || 1); }

  input.addEventListener("input", () => update(getVal()));
  downBtn.addEventListener("click", () => {
    const next = Math.max(1, getVal() - 1);
    input.value = String(next);
    update(next);
  });
  upBtn.addEventListener("click", () => {
    const next = getVal() + 1;
    input.value = String(next);
    update(next);
  });
</script>

<style>
  .calculator {
    background-color: var(--bg-secondary);
    padding-block: clamp(var(--space-1600), 10vw, var(--space-2400));
  }

  .calculator__card {
    padding: clamp(var(--space-800), 6vw, var(--space-1600));
    display: flex;
    flex-direction: column;
    gap: var(--space-1200);
    box-shadow: var(--shadow-md);
  }

  .calculator__header {
    display: flex;
    align-items: center;
    gap: var(--space-400);
    justify-content: center;
  }

  .calculator__icon {
    flex-shrink: 0;
  }

  .calculator__heading {
    font-family: var(--font-sans);
    font-size: var(--size-07);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--text-default);
    margin: 0;
  }

  .calculator__body {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: 0;
    align-items: center;
  }

  .calculator__input-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-400);
  }

  .calculator__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-400);
  }

  .calculator__label {
    font-family: var(--font-sans);
    font-size: var(--size-03);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
    color: var(--text-default);
  }

  .calculator__stepper {
    display: inline-flex;
    align-items: center;
    border: var(--stroke-border) solid var(--border-default);
    border-radius: var(--radius-200);
    background-color: var(--bg-default);
    overflow: hidden;
    width: fit-content;
  }

  .calculator__stepper-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    color: var(--icon-default);
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease, color 0.15s ease, transform 0.1s ease;
  }

  .calculator__stepper-btn:hover {
    background-color: var(--bg-brand-tertiary);
    color: var(--text-brand);
  }

  .calculator__stepper-btn:active {
    transform: scale(0.9);
  }

  .calculator__stepper-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .calculator__stepper-input {
    width: 60px;
    text-align: center;
    border: none;
    border-left: var(--stroke-border) solid var(--border-default);
    border-right: var(--stroke-border) solid var(--border-default);
    font-family: var(--font-sans);
    font-size: var(--size-05);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-default);
    padding: var(--space-200) 0;
    font-variant-numeric: tabular-nums;
    -moz-appearance: textfield;
  }

  .calculator__stepper-input::-webkit-outer-spin-button,
  .calculator__stepper-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .calculator__stepper-input:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .calculator__metric {
    flex: 1;
    min-width: 0;
    padding-inline: var(--space-800);
    border-left: var(--stroke-border) solid var(--border-default);
  }

  .calculator__metric-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-100);
  }

  .calculator__metric-label {
    font-family: var(--font-sans);
    font-size: var(--size-02);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .calculator__metric-value {
    font-family: var(--font-sans);
    font-size: var(--size-06);
    font-weight: var(--weight-bold);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--text-brand);
    font-variant-numeric: tabular-nums;
    word-break: break-word;
    margin-top: 20px;
  }

  .calculator__metric-note {
    font-family: var(--font-sans);
    font-size: var(--size-02);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
  }

  .calculator__impact {
    display: flex;
    align-items: flex-start;
    gap: var(--space-400);
    border-top: var(--stroke-border) solid var(--border-default);
    padding-top: var(--space-800);
  }

  .calculator__impact-icon {
    flex-shrink: 0;
    align-self: center;
  }

  .calculator__impact-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-200);
  }

  .calculator__impact-line {
    font-family: var(--font-sans);
    font-size: var(--size-04);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    margin: 0;
  }

  .calculator__impact-line strong {
    font-weight: var(--weight-bold);
    color: var(--text-brand);
    font-variant-numeric: tabular-nums;
    margin-inline: 0.15em;
  }

  @media (max-width: 1024px) {
    .calculator__card {
      gap: var(--space-800);
    }

    .calculator__body {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-600);
    }

    .calculator__input-panel {
      grid-column: 1 / -1;
    }

    .calculator__metric {
      border-left: none;
      padding-inline: 0;
    }

    .calculator__header {
      flex-wrap: wrap;
    }

    .calculator__heading {
      font-size: var(--size-06);
    }
  }

  @media (max-width: 540px) {
    .calculator__body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .calculator__heading {
      font-size: var(--size-05);
    }

    .calculator__body {
      gap: var(--space-800);
    }

    .calculator__stepper {
      max-width: 180px;
    }

    .calculator__stepper-btn {
      width: 40px;
      height: 40px;
    }

    .calculator__stepper-input {
      width: 50px;
      font-size: var(--size-04);
    }

    .calculator__metric-value {
      font-size: var(--size-06);
    }

    .calculator__impact {
      padding-top: var(--space-600);
    }

    .calculator__impact-line {
      font-size: var(--size-03);
    }
  }
</style>
