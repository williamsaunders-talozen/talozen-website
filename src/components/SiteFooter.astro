---
interface Link {
  label: string;
  href: string;
}

interface LinkGroup {
  title: string;
  links: Link[];
}

interface Props {
  linkGroups: LinkGroup[];
}

const { linkGroups } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="tz-container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo" aria-label="Talozen home">
        <img
          src="/talozen-logo.svg"
          alt="Talozen"
          width="142"
          height="24"
          class="site-footer__logo-img"
        />
      </a>
      <div class="site-footer__social">
        <a href="https://www.linkedin.com/company/talozenplatform/" class="site-footer__social-link tz-focus" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>

    <nav class="site-footer__nav" aria-label="Footer navigation">
      {linkGroups.map((group) => (
        <div class="site-footer__group">
          <h3 class="site-footer__group-title">{group.title}</h3>
          <ul class="site-footer__links">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="site-footer__link tz-focus">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="site-footer__bottom">
    <div class="tz-container">
      <p class="site-footer__copyright">&copy; Talozen Oy {year}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--bg-default);
    border-top: var(--stroke-border) solid var(--border-default);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-400);
    align-items: flex-start;
    padding-block: var(--space-1600);
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-600);
    flex-shrink: 0;
    width: 262px;
  }

  .site-footer__logo {
    display: inline-block;
    text-decoration: none;
    border-radius: var(--radius-100);
  }

  .site-footer__logo:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .site-footer__logo-img {
    display: block;
    height: var(--icon-sm);
    width: auto;
  }

  .site-footer__social {
    display: flex;
    align-items: center;
    gap: var(--space-400);
  }

  .site-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--icon-secondary);
    text-decoration: none;
    border-radius: var(--radius-100);
    transition: color 0.15s ease;
  }

  .site-footer__social-link:hover {
    color: var(--icon-default);
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-400);
    flex: 1;
  }

  .site-footer__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
    min-width: 160px;
    flex: 1;
  }

  .site-footer__group-title {
    font-family: var(--font-sans);
    font-size: var(--size-03);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-normal);
    color: var(--text-default);
    margin: 0;
    padding-bottom: var(--space-400);
    border-bottom: var(--stroke-border) solid var(--border-default);
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-300);
  }

  .site-footer__link {
    font-family: var(--font-sans);
    font-size: var(--size-03);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--text-default);
    text-decoration: none;
    border-radius: var(--radius-100);
    transition: color 0.15s ease;
  }

  .site-footer__link:hover {
    color: var(--text-brand);
  }

  .site-footer__bottom {
    border-top: var(--stroke-border) solid var(--border-default);
    padding-block: var(--space-400);
  }

  .site-footer__copyright {
    font-family: var(--font-sans);
    font-size: var(--size-02);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    margin: 0;
  }
</style>
